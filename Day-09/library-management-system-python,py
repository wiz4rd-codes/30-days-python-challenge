class Library : 
    def __init__(self,num_book,books):
        self.no_books = num_book
        self.books = books
    def length(self):
        if(len(self.books)== self.no_books):
            print("length of list of book is equal to number of book")
        else : 
            print("There is an Error !!!\nNumber of book is not equal to length of list of books ")

    def display(self):
        print(f"Total number of book : {self.no_books}")
        for  i,book in enumerate(self.books, start = 1):
            print(f"Book number {i} : {book}")
